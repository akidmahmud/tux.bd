# Garage secrets — NOT committed to git (listed in .gitignore).
# Copy this file to secrets.env and fill in the values.
#
# Generate values with:
#   openssl rand -hex 32       # for GARAGE_RPC_SECRET
#   openssl rand -base64 32    # for GARAGE_ADMIN_TOKEN
GARAGE_RPC_SECRET=replace-with-openssl-rand-hex-32
GARAGE_ADMIN_TOKEN=replace-with-openssl-rand-base64-32
