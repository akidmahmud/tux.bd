# Traefik secrets — NOT committed to git (listed in .gitignore).
# Copy this file to secrets.env and fill in the values.
#
# Create a Cloudflare API token at:
#   https://dash.cloudflare.com/profile/api-tokens
#   Permissions required: Zone:DNS:Edit for tux.bd
CF_DNS_API_TOKEN=replace-with-cloudflare-api-token
